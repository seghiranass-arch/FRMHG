// Hockey positions
const POSITIONS = ['Gardien', 'Défenseur', 'Milieu', 'Attaquant'];

// Venues in Morocco
const VENUES = [
  'Complexe Mohammed VI - Casablanca',
  'Palais des Sports - Rabat',
  'Salle Omnisports - Marrakech',
  'Centre Sportif Municipal - Tanger',
  'Salle Ibn Batouta - Fès',
  'Complexe Sportif - Agadir',
  'Patinoire Régionale - Kenitra',
  'Centre des Sports - Meknès'
];

function getRandomDate(start: Date, end: Date): Date {
  return new Date(start.getTime() + Math.random() * (end.getTime() - start.getTime()));
}

function generateRandomPlayer(orgId: string) {
  const firstName = PLAYER_FIRST_NAMES[Math.floor(Math.random() * PLAYER_FIRST_NAMES.length)];
  const lastName = PLAYER_LAST_NAMES[Math.floor(Math.random() * PLAYER_LAST_NAMES.length)];
  const position = POSITIONS[Math.floor(Math.random() * POSITIONS.length)];
  
  // Generate realistic stats based on position
  let goals = 0;
  let assists = 0;
  let gamesPlayed = Math.floor(Math.random() * 30) + 5; // 5-35 games
  
  if (position !== 'Gardien') {
    goals = Math.floor(Math.random() * (gamesPlayed / 2)); // 0 to games/2
    assists = Math.floor(Math.random() * (gamesPlayed / 1.5)); // 0 to games/1.5
  }
  
  return {
    firstName,
    lastName,
    email: `${firstName.toLowerCase()}.${lastName.toLowerCase()}@example.com`,
    phone: `+212 6 ${Math.floor(Math.random() * 90000000) + 10000000}`,
    dateOfBirth: getRandomDate(new Date(1990, 0, 1), new Date(2005, 11, 31)),
    nationality: 'Marocaine',
    category: 'joueur_club' as const,
    licenseStatus: 'active' as const,
    licenseExpiry: new Date(2026, 11, 31),
    position,
    jerseyNumber: Math.floor(Math.random() * 99) + 1,
    goals,
    assists,
    gamesPlayed,
    orgId
  };
}

async function main() {
  console.log('Generating realistic FRMHG data...');
  
  // 1. Create enhanced clubs
  console.log('\n1. Creating clubs...');
  for (const clubData of MOROCCAN_CLUBS) {
    const club = await prisma.org.upsert({
      where: { id: clubData.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') },
      update: clubData,
      create: {
        ...clubData,
        id: clubData.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
      }
    });
    console.log(`  ✓ ${club.name}`);
  }
  
  // 2. Generate realistic players (500+ players)
  console.log('\n2. Generating players...');
  const clubs = await prisma.org.findMany();
  let totalPlayers = 0;
  
  for (const club of clubs) {
    // Generate 30-50 players per club
    const playerCount = Math.floor(Math.random() * 21) + 30; // 30-50 players
    
    for (let i = 0; i < playerCount; i++) {
      const playerData = generateRandomPlayer(club.id);
      await prisma.member.create({
        data: playerData
      });
      totalPlayers++;
    }
    console.log(`  ✓ ${club.name}: ${playerCount} players`);
  }
  console.log(`  Total players created: ${totalPlayers}`);
  
  // 3. Create competitions
  console.log('\n3. Creating competitions...');
  const createdCompetitions = [];
  for (const compData of COMPETITIONS) {
    const competition = await prisma.competition.create({
      data: compData
    });
    createdCompetitions.push(competition);
    console.log(`  ✓ ${competition.name} (${competition.season})`);
  }
  
  // 4. Generate match schedules
  console.log('\n4. Generating match schedules...');
  let totalMatches = 0;
  
  for (const competition of createdCompetitions) {
    // Generate round-robin matches for each competition
    const activeClubs = clubs.filter((c: any) => c.status === 'active');
    const matchCount = Math.min(activeClubs.length * 2, 50); // Limit matches per competition
    
    for (let i = 0; i < matchCount; i++) {
      const homeTeam = activeClubs[Math.floor(Math.random() * activeClubs.length)];
      let awayTeam;
      do {
        awayTeam = activeClubs[Math.floor(Math.random() * activeClubs.length)];
      } while (awayTeam.id === homeTeam.id);
      
      const matchDate = getRandomDate(competition.startDate, competition.endDate);
      
      await prisma.match.create({
        data: {
          competitionId: competition.id,
          homeTeamId: homeTeam.id,
          awayTeamId: awayTeam.id,
          date: matchDate,
          venue: VENUES[Math.floor(Math.random() * VENUES.length)],
          status: Math.random() > 0.7 ? 'completed' : 'scheduled' // 30% completed, 70% scheduled
        }
      });
      totalMatches++;
    }
    console.log(`  ✓ ${competition.name}: ${matchCount} matches`);
  }
  console.log(`  Total matches created: ${totalMatches}`);
  
  // 5. Update some matches with scores
  console.log('\n5. Adding match results...');
  const scheduledMatches = await prisma.match.findMany({
    where: { status: 'completed' },
    take: 30
  });
  
  for (const match of scheduledMatches) {
    // Generate realistic scores (most games are close)
    const scoreDiff = Math.random() > 0.8 ? Math.floor(Math.random() * 4) + 1 : Math.floor(Math.random() * 2);
    const winnerScore = Math.floor(Math.random() * 3) + scoreDiff;
    const loserScore = winnerScore - scoreDiff;
    
    const homeWins = Math.random() > 0.5;
    const homeScore = homeWins ? winnerScore : loserScore;
    const awayScore = homeWins ? loserScore : winnerScore;
    
    await prisma.match.update({
      where: { id: match.id },
      data: {
        homeScore,
        awayScore,
        status: 'completed'
      }
    });
  }
  console.log(`  ✓ Updated ${scheduledMatches.length} matches with scores`);
  
  // 6. Create realistic documents
  console.log('\n6. Creating sample documents...');
  const members = await prisma.member.findMany({ take: 20 });
  const orgs = await prisma.org.findMany({ take: 10 });
  
  // Create various document types
  const documentTypes = ['photo', 'id_card', 'medical_certificate', 'insurance', 'contract'];
  
  for (let i = 0; i < 50; i++) {
    const isForMember = Math.random() > 0.4; // 60% for members, 40% for orgs
    
    await prisma.document.create({
      data: {
        filename: `doc-${Date.now()}-${i}.pdf`,
        originalName: `document_${i + 1}.pdf`,
        mimeType: 'application/pdf',
        size: Math.floor(Math.random() * 2000000) + 100000, // 100KB - 2MB
        type: documentTypes[Math.floor(Math.random() * documentTypes.length)] as any,
        description: `Document généré automatiquement #${i + 1}`,
        ...(isForMember 
          ? { memberId: members[Math.floor(Math.random() * members.length)].id }
          : { orgId: orgs[Math.floor(Math.random() * orgs.length)].id }
        )
      }
    });
  }
  console.log(`  ✓ Created 50 sample documents`);
  
  console.log('\n✅ Data generation completed successfully!');
  console.log(`📊 Summary:`);
  console.log(`   • Clubs: ${clubs.length}`);
  console.log(`   • Players: ${totalPlayers}`);
  console.log(`   • Competitions: ${createdCompetitions.length}`);
  console.log(`   • Matches: ${totalMatches}`);
  console.log(`   • Documents: 50`);
}

main()
  .catch((e) => {
    console.error('❌ Error during data generation:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });