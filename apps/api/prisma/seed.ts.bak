    region: 'Tanger-Tétouan-Al Hoceïma',
    city: 'Tanger',
    primaryPhone: '+212 5 39 345678',
    officialEmail: 'info@hct.ma',
    presidentName: 'Youssef Tazi',
  },
  {
    name: 'Club Athlétique Fès',
    acronym: 'CAF',
    type: 'club' as const,
    status: 'suspended' as const,
    region: 'Fès-Meknès',
    city: 'Fès',
    primaryPhone: '+212 5 35 567890',
    officialEmail: 'contact@caf.ma',
    presidentName: 'Rachid Berrada',
    suspensionReason: 'Documents administratifs non conformes',
  },
];

async function main() {
  console.log('Seeding database...');

  // Create users
  for (const userData of TEST_USERS) {
    const hashedPassword = await bcrypt.hash(userData.password, 10);
    
    await prisma.user.upsert({
      where: { email: userData.email },
      update: {
        password: hashedPassword,
        displayName: userData.displayName,
        roles: userData.roles,
      },
      create: {
        email: userData.email,
        password: hashedPassword,
        displayName: userData.displayName,
        roles: userData.roles,
      },
    });
    console.log(`  User: ${userData.email}`);
  }

  // Create clubs
  for (const clubData of SAMPLE_CLUBS) {
    await prisma.org.upsert({
      where: { id: clubData.name.toLowerCase().replace(/\s+/g, '-') },
      update: clubData,
      create: {
        id: clubData.name.toLowerCase().replace(/\s+/g, '-'),
        ...clubData,
      },
    });
    console.log(`  Club: ${clubData.name}`);
  }

  // Create some sample members
  const clubs = await prisma.org.findMany();
  if (clubs.length > 0) {
    const sampleMembers = [
      { firstName: 'Mohamed', lastName: 'Alaoui', category: 'joueur_club' as const, position: 'Forward', jerseyNumber: 10 },
      { firstName: 'Yassine', lastName: 'Benali', category: 'joueur_club' as const, position: 'Defender', jerseyNumber: 4 },
      { firstName: 'Fatima', lastName: 'Zahra', category: 'ecole_glace' as const },
      { firstName: 'Karim', lastName: 'Idrissi', category: 'joueur_club' as const, position: 'Goalie', jerseyNumber: 1 },
      { firstName: 'Amina', lastName: 'Chaoui', category: 'ecole_glace' as const },
    ];

    for (let i = 0; i < sampleMembers.length; i++) {
      const member = sampleMembers[i];
      const club = clubs[i % clubs.length];
      
      await prisma.member.create({
        data: {
          ...member,
          email: `${member.firstName.toLowerCase()}.${member.lastName.toLowerCase()}@example.com`,
          licenseStatus: member.category === 'joueur_club' ? 'active' : 'pending',
          orgId: club.id,
        },
      });
      console.log(`  Member: ${member.firstName} ${member.lastName} -> ${club.name}`);
    }
  }

  console.log('Seeding completed!');
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
