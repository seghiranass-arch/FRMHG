// Sample clubs
const SAMPLE_CLUBS = [
  {
    name: 'Club Hockey Casablanca',
    acronym: 'CHC',
    type: 'club' as const,
    status: 'active' as const,
    region: 'Casablanca-Settat',
    city: 'Casablanca',
    primaryPhone: '+212 5 22 123456',
    officialEmail: 'contact@chc.ma',
    presidentName: 'Ahmed Bennani',
  },
  {
    name: 'Association Hockey Rabat',
    acronym: 'AHR',
    type: 'club' as const,
    status: 'active' as const,
    region: 'Rabat-Salé-Kénitra',
    city: 'Rabat',
    primaryPhone: '+212 5 37 654321',
    officialEmail: 'info@ahr.ma',
    presidentName: 'Karim El Fassi',
  },
  {
    name: 'Club Sportif Marrakech',
    acronym: 'CSM',
    type: 'club' as const,
    status: 'pending' as const,
    region: 'Marrakech-Safi',
    city: 'Marrakech',
    primaryPhone: '+212 5 24 789012',
    officialEmail: 'contact@csm.ma',
